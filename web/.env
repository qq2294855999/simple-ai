# Simple AI 前端环境变量
# OAuth 统一认证中心地址
VITE_OAUTH_LOGIN_URL="http://localhost:5173"

# 客户端标识与密钥（与 OAuth sys_project_client 对应，用于 Basic Auth）
VITE_CLIENT_ID=simple-ai
VITE_CLIENT_SECRET=123456

# 登录页自定义文案
VITE_LOGIN_TITLE=Simple AI 平台
VITE_LOGIN_SUBTITLE=智能体管理平台
VITE_LOGIN_FOOTER_TIP=忘记密码？请联系AI平台管理员

# API 基础路径
VITE_API_BASE_URL=/api
